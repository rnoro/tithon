{
  "name": "tithon",
  "displayName": "Tithon",
  "version": "0.1.0",
  "private": true,
  "publisher": "rnoro",
  "license": "MIT",
  "icon": "icon.png",
  "categories": [
    "Notebooks",
    "Data Science",
    "Machine Learning"
  ],
  "keywords": [
    "jupyter",
    "notebook",
    "kernel",
    "remote",
    "persistent",
    "ipywidgets"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/rnoro/tithon.git"
  },
  "bugs": {
    "url": "https://github.com/rnoro/tithon/issues"
  },
  "homepage": "https://github.com/rnoro/tithon#readme",
  "description": "Tithon VSCode extension — percent Cell View + matplotlib/tqdm output + output restore",
  "engines": {
    "vscode": "^1.85.0"
  },
  "type": "commonjs",
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished",
    "onLanguage:python",
    "onNotebook:tithon-py",
    "onCommand:tithon.runCell"
  ],
  "contributes": {
    "notebooks": [
      {
        "type": "tithon-py",
        "displayName": "Tithon Cell View",
        "selector": [
          {
            "filenamePattern": "*.py"
          }
        ]
      }
    ],
    "notebookRenderer": [
      {
        "id": "tithon-widget",
        "displayName": "Tithon ipywidget renderer",
        "entrypoint": "./dist/widgetRenderer.js",
        "requiresMessaging": "optional",
        "mimeTypes": [
          "application/vnd.tithon.widget+json"
        ]
      }
    ],
    "commands": [
      {
        "command": "tithon.restartKernel",
        "title": "Tithon: Restart Kernel",
        "category": "Tithon",
        "icon": "$(debug-restart)"
      },
      {
        "command": "tithon.interruptKernel",
        "title": "Tithon: Interrupt Kernel",
        "category": "Tithon",
        "icon": "$(debug-stop)"
      },
      {
        "command": "tithon.restoreOutputs",
        "title": "Tithon: Resync Outputs from Daemon",
        "category": "Tithon"
      },
      {
        "command": "tithon.startLive",
        "title": "Tithon: Start Live Output Sync",
        "category": "Tithon"
      },
      {
        "command": "tithon.openAsCellView",
        "title": "Open as Cell View",
        "category": "Tithon",
        "icon": "$(notebook)"
      },
      {
        "command": "tithon.openAsText",
        "title": "Open as Text Editor",
        "category": "Tithon",
        "icon": "$(file-code)"
      },
      {
        "command": "tithon.selectInterpreter",
        "title": "Tithon: Select Python Interpreter",
        "category": "Tithon",
        "icon": "$(snake)"
      },
      {
        "command": "tithon.restartDaemon",
        "title": "Tithon: Restart Daemon",
        "category": "Tithon"
      },
      {
        "command": "tithon.killKernel",
        "title": "Tithon: Terminate Kernel…",
        "category": "Tithon",
        "icon": "$(trash)"
      }
    ],
    "configuration": {
      "title": "Tithon",
      "properties": {
        "tithon.autoStartDaemon": {
          "type": "boolean",
          "default": true,
          "description": "Automatically start the Tithon daemon on the host when it isn't already running (spawned detached, so it survives reconnects)."
        },
        "tithon.daemonCommand": {
          "type": "string",
          "default": "tithon",
          "description": "Command used to launch the daemon (run as `<command> daemon`). Set to an absolute path if `tithon` is not on PATH."
        },
        "tithon.pythonPath": {
          "type": "string",
          "default": "",
          "description": "Python interpreter to run the daemon as `<python> -m tithon daemon` (works without activating the venv). Leave empty to use the interpreter selected by the Python extension."
        },
        "tithon.autoOpenCellView": {
          "type": "boolean",
          "default": true,
          "description": "Automatically open percent-format `.py` files (those with a `# %%` cell marker) in the Tithon Cell View instead of as plain text. Plain scripts with no markers are unaffected. Use the Cell View toolbar's \"Open as Text Editor\" to keep a given file as text for the session."
        }
      }
    },
    "menus": {
      "editor/title": [
        {
          "command": "tithon.openAsCellView",
          "when": "resourceExtname == .py && activeEditor == workbench.editors.files.textFileEditor",
          "group": "navigation"
        },
        {
          "command": "tithon.openAsText",
          "when": "notebookType == tithon-py",
          "group": "navigation"
        }
      ],
      "notebook/toolbar": [
        {
          "command": "tithon.interruptKernel",
          "when": "notebookType == tithon-py",
          "group": "navigation/execute@1"
        },
        {
          "command": "tithon.restartKernel",
          "when": "notebookType == tithon-py",
          "group": "navigation/execute@2"
        },
        {
          "command": "tithon.selectInterpreter",
          "when": "notebookType == tithon-py",
          "group": "navigation/view@1"
        },
        {
          "command": "tithon.killKernel",
          "when": "notebookType == tithon-py",
          "group": "kernel@1"
        }
      ],
      "commandPalette": [
        {
          "command": "tithon.killKernel"
        }
      ]
    }
  },
  "scripts": {
    "test": "vitest run",
    "test:serializer": "vitest run test/serializer.test.ts test/cellAttach.test.ts",
    "test:widget": "vitest run test/widget.test.ts",
    "build": "tsc -p ./",
    "bundle": "node esbuild.mjs",
    "vscode:prepublish": "node esbuild.mjs"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@vscode/test-electron": "^3.0.0",
    "fast-check": "^3.15.0",
    "glob": "^13.0.6",
    "jsdom": "^24.0.0",
    "mocha": "^11.7.6",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0",
    "@types/ws": "^8.18.1",
    "vsce": "^2.15.0"
  },
  "dependencies": {
    "@jupyter-widgets/base": "^6.0.11",
    "@jupyter-widgets/controls": "^5.0.12",
    "@jupyter-widgets/html-manager": "^1.0.14",
    "ws": "^8.21.0"
  }
}
